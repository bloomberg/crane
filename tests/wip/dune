(include_subdirs qualified)

(env (_ (env-vars (INSIDE_DUNE "1"))))

(coq.theory
 (name CraneTestsWIP)
 (synopsis "Tests for the rocq-crane plugin")
 (modules :standard) ; automatically includes all .v files in this directory
 (theories
   Stdlib
   Crane
   ITree ExtLib Paco)
 (flags (:standard -output-directory ../../tests/wip)))


(subdir skiplist_bde
 (rule
  (targets skiplist_bde.t.exe)
  (deps SkipList.vo skiplist_bde.t.cpp (source_tree .))
  (action
   (run %{project_root}/scripts/compile-bde.sh %{project_root} skiplist_bde.t.exe skiplist_bde.cpp skiplist_bde.t.cpp)))
 (rule
  (alias runtest)
  (deps skiplist_bde.t.exe)
  (action (run ./skiplist_bde.t.exe))))

