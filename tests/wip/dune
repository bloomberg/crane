(include_subdirs qualified)

(env (_ (env-vars (INSIDE_DUNE "1"))))

(coq.theory
 (name CraneTestsWIP)
 (synopsis "Tests for the rocq-crane plugin")
 (modules :standard) ; automatically includes all .v files in this directory
 (theories
   Stdlib
   Crane)
 (flags (:standard -output-directory ../../tests/wip)))


(subdir load_program_head_write
 (rule
  (targets load_program_head_write.t.exe)
  (deps LoadProgramHeadWrite.vo load_program_head_write.t.cpp (source_tree .))
  (action
   (run %{project_root}/scripts/compile-std.sh %{project_root} load_program_head_write.t.exe load_program_head_write.cpp load_program_head_write.t.cpp)))
 (rule
  (alias runtest)
  (deps load_program_head_write.t.exe)
  (action (run ./load_program_head_write.t.exe))))

