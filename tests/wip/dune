(subdir cotree
 (rule
  (targets cotree.t.exe)
  (deps Cotree.vo cotree.t.cpp (source_tree .))
  (action
   (run %{project_root}/scripts/compile-std.sh %{project_root} cotree.t.exe cotree.cpp cotree.t.cpp)))
 (rule
  (alias runtest)
  (deps cotree.t.exe)
  (action (run ./cotree.t.exe))))

